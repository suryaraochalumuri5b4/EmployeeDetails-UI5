<mvc:View xmlns:core="sap.ui.core" xmlns:form="sap.ui.layout.form" controllerName="chip.controller.myXmlView" xmlns="sap.m" xmlns:mvc="sap.ui.core.mvc" xmlns:t="sap.ui.table">

<!-- <Input placeholder="Enter your name" id="idText" enabled="true" />
<Button text="Press Me" press="onPress" id="idButton" icon="sap-icon://action"/> -->
<t:Table rows="{/empTab}" alternateRowColors="true" visibleRowCount="5" selectionMode="Single" rowSelectionChange="onRowSelect">
 <t:columns>
  <t:Column >
    <t:label>
      <Label text="{i18n>XLBL_EMPID}"></Label>
    </t:label>
    <t:template>
    <Text text="{empID}"></Text>
    </t:template>
  </t:Column>
   <t:Column >
    <t:label>
      <Label text="{i18n>XLBL_EMPNAME}"></Label>
    </t:label>
     <t:template>
    <Text text="{parts:[{path:'empName'}],
                 formatter:'.myFormatter.formatEmpName'}">
    </Text>
    </t:template>
  </t:Column>
   <t:Column >
    <t:label>
      <Label text="{i18n>XLBL_EMPDEPT}"></Label>
    </t:label>
     <t:template>
    <Text text="{empDept}"></Text>
    </t:template>
  </t:Column>
   <t:Column >
    <t:label>
      <Label text="{i18n>XLBL_EMPSALARY}"></Label>
    </t:label>
     <t:template>
     <Text text="{parts:[{path:'empSalary'},{path:'currency'}],
                 formatter:'.myFormatter.formatCurrency'}">
    </Text>
    </t:template>
  </t:Column>
  <t:Column >
    <t:label>
      <Label text="{i18n>XLBL_GENDER}"></Label>
    </t:label>
     <t:template>
     <Image src="{gender}" width="20px" height="20px"/>
    </t:template>
  </t:Column>
   <t:Column >
    <t:label>
      <Label text="{i18n>XLBL_EMPDOB}"></Label>
    </t:label>
     <t:template>
      <Text text="{
            path: 'empDob',
            formatter: '.myFormatter.formatDate'
        }" />
    </t:template>
  </t:Column>
  <t:Column >
    <t:label>
      <Label text="{i18n>XLBL_RATING}"></Label>
    </t:label>
     <t:template>
    <RatingIndicator displayOnly="true" value="{rating}"  />
    </t:template>
  </t:Column>
 </t:columns>
</t:Table>
<VBox justifyContent="Center" width="100%">
<form:SimpleForm  id="idSimple" layout="ResponsiveLayout" >
 <form:title>
   <core:Title text=" {i18n>XLBL_EMPTITLE}" icon="sap-icon://customer"></core:Title>
 </form:title>
 <form:content>
   <Label text="{i18n>XLBL_EMPID}" textAlign="Right"></Label>
   <Input id="idEmpID" width="150px" value="{empID}"></Input>
   <Label text="{i18n>XLBL_EMPNAME}" ></Label>
   <Input id="idEmpName" width="150px" value="{empName}"></Input>
   <Label text="{i18n>XLBL_EMPSALARY}"></Label>
    <Input id="idEmpSalary" width="150px"  value="{empSalary}" ></Input>
    <Label text="{i18n>XLBL_EMPDEPT}"></Label>
    <Input id="idEmpDept" width="150px"  value="{empDept}"></Input>
    <Label ></Label>
    <Button text="Reload" press="onReload" width="80px"></Button>

 </form:content>

</form:SimpleForm>
</VBox>


</mvc:View>
    